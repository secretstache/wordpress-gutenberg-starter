/**
* @param {string} class
* @param {string} style
* @param {string} background
* @param {string} align - full | wide
* @param {string} id
* @param {string} customStyle
* @param {string} gradient
*/

{% macro render(props) %}

    {% set classes = buildClasses(props, []) %}

    {% set styles = buildStyles(props, []) | safe %}

    {% set id = ' id="' + props.id + '"' if props.id %}

    <hr class="wp-block-separator{{ classes }}"{{ styles }}{{ id }}>

{% endmacro %}
