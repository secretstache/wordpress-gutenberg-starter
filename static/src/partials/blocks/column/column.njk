/**
    * @param {string} class
    * @param {string} style
    * @param {string} color
    * @param {string} background
    * @param {string} fontSize
    * @param {string} contentWidth
    * @param {string} justification - left, center, right
    * @param {string} width
    * @param {boolean} verticalAlign - center | top | bottom
    * @param {string} id
    * @param {string} customStyle
*/

{% macro render(props) %}

  {% from "macros/blocks.njk" import block %}

  {% if props.contentWidth or props.justification%}
    {% set uid = uid() %}
  {% endif %}

  {% set classes = buildClasses(props, [
    'is-layout-flow',
    'wp-container-'+ uid if props.contentWidth or props.justification
  ]) %}

  {% set styles = buildStyles(props, [
    'flex-basis:' + props.width if props.width
  ]) | safe %}

  {%  set id = ' id="' + props.id + '"' if props.id %}

  <div class="wp-block-column{{ classes }}"{{ styles }}{{ id }}>

    {% if caller %}{{ caller() | safe }}{% endif %}

    {% if props.contentWidth or props.justification %}

      <!--for static purpose only -->
      <style>
        .wp-container-{{ uid }}.wp-container-{{ uid }} > :where(:not(.alignleft):not(.alignright):not(.alignfull)) {
          max-width: {{ props.contentWidth }};
          margin-left: {% if props.justification === 'left' %}0{% else %}auto{% endif %} !important;
          margin-right: {% if props.justification === 'right' %}0{% else %}auto{% endif %} !important;
        }
      </style>

    {% endif %}

  </div>

{% endmacro %}
